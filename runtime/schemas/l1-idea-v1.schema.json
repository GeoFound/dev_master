{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "L1 Idea Spec",
  "type": "object",
  "required": [
    "schema_version",
    "idea_id",
    "title",
    "audience",
    "problem",
    "promise",
    "primary_actions"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "idea_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "type": "string",
      "minLength": 1
    },
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "promise": {
      "type": "string",
      "minLength": 1
    },
    "primary_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "success_signal": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
